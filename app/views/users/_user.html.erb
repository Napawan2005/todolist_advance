<div id="<%= dom_id user %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Keycloak uid:</strong>
    <%= user.keycloak_uid %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Email:</strong>
    <%= user.email %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Full name:</strong>
    <%= user.full_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Avatar url:</strong>
    <%= user.avatar_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Google access token:</strong>
    <%= user.google_access_token %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Google token expire at:</strong>
    <%= user.google_token_expire_at %>
  </div>
</div>
